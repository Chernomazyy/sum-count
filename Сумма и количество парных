using System;

namespace project3
{
    class Program
    {
        static void Main(string[] args)
        {
            int N = Convert.ToInt32(Console.ReadLine());
            int sum = 0;
            int k = 0;
            for(int i = 1;i<=N;i++)
            {
                if(i % 2 == 0)
                { sum += i; k += 1; }
            }
            Console.WriteLine(k);
            Console.WriteLine(sum);
            

        }
    }
}
